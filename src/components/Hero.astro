---
import { site } from "../content/site";
---

<section
  class="relative flex min-h-screen items-center justify-center overflow-hidden"
>
  <!-- Gradient mesh background -->
  <div
    class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_top_right,_rgba(99,102,241,0.15),_transparent_50%),_radial-gradient(ellipse_at_bottom_left,_rgba(99,102,241,0.1),_transparent_50%)]"
  >
  </div>

  <div class="mx-auto max-w-4xl px-6 py-24 text-center">
    <p
      class="mb-4 font-mono text-sm tracking-wider text-accent animate-fade-in"
    >
      Hello, I'm
    </p>
    <h1
      class="mb-4 text-5xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 sm:text-6xl lg:text-7xl animate-fade-in [animation-delay:100ms]"
    >
      {site.name}
    </h1>
    <p
      class="mb-6 text-xl text-neutral-600 dark:text-neutral-400 sm:text-2xl animate-fade-in [animation-delay:200ms]"
    >
      {site.title}
    </p>
    <p
      class="mb-10 text-lg text-neutral-500 dark:text-neutral-500 animate-fade-in [animation-delay:300ms]"
    >
      {site.tagline}
    </p>
    <a
      href="#contact"
      class="inline-block rounded-lg bg-accent px-6 py-3 text-sm font-medium text-white transition-all hover:bg-accent-light hover:shadow-lg hover:shadow-accent/25 animate-fade-in [animation-delay:400ms]"
    >
      Get in Touch
    </a>
  </div>
</section>

<style>
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    opacity: 0;
    animation: fade-in 0.6s ease-out forwards;
  }
</style>
