---
interface Props {
  command: string;
}

const { command } = Astro.props;
---

<div class="terminal-block mb-6">
  <div class="command mb-1">
    <span class="text-green-500 dark:text-green-400">$</span>
    <span class="typed-command ml-2 text-neutral-800 dark:text-neutral-200">{command}</span>
  </div>
  <div class="output text-neutral-600 dark:text-neutral-400">
    <slot />
  </div>
</div>
