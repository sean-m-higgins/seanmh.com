---
import type { ExperienceEntry } from "../content/experience";

interface Props {
  entry: ExperienceEntry;
}

const { entry } = Astro.props;
const isEducation = entry.type === "education";
---

<div class="relative pl-8 pb-10 last:pb-0 group">
  <!-- Timeline line -->
  <div
    class="absolute left-0 top-1.5 h-full w-px bg-neutral-200 dark:bg-neutral-800 group-last:hidden"
  >
  </div>
  <!-- Timeline dot -->
  <div
    class="absolute left-[-4px] top-1.5 h-2.5 w-2.5 rounded-full border-2 border-accent bg-white dark:bg-[#0a0a0a]"
  >
  </div>

  <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
    <div>
      <h3 class="font-semibold text-neutral-900 dark:text-neutral-100">
        {entry.title}
      </h3>
      <p class="text-sm text-accent">
        {
          entry.url ? (
            <a
              href={entry.url}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:underline"
            >
              {entry.organization}
            </a>
          ) : (
            entry.organization
          )
        }
      </p>
    </div>
    <span
      class="shrink-0 font-mono text-xs text-neutral-500 dark:text-neutral-500"
    >
      {entry.dates}
    </span>
  </div>
  <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400">
    {entry.description}
  </p>
</div>
