---
const links = [
  { label: "About", href: "/#about" },
  { label: "Experience", href: "/#experience" },
  { label: "Contact", href: "/#contact" },
];
---

<nav
  class="fixed top-0 z-50 w-full border-b border-neutral-200/10 bg-white/80 backdrop-blur-lg dark:bg-[#0a0a0a]/80"
>
  <div class="mx-auto flex max-w-4xl items-center justify-between px-6 py-3">
    <a
      href="/"
      class="text-xl font-bold tracking-tight text-accent transition-opacity hover:opacity-80"
    >
      SH
    </a>

    <!-- Desktop links -->
    <div class="hidden items-center gap-6 md:flex">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-neutral-600 transition-colors hover:text-accent dark:text-neutral-400 dark:hover:text-accent-light"
          >
            {link.label}
          </a>
        ))
      }
      <button
        id="dark-toggle-desktop"
        aria-label="Toggle dark mode"
        class="rounded-lg p-2 transition-colors hover:bg-neutral-100 dark:hover:bg-neutral-800"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg class="h-5 w-5 text-yellow-400 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg class="h-5 w-5 text-neutral-700 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="flex items-center md:hidden"
      aria-label="Toggle menu"
    >
      <svg
        class="h-6 w-6 text-neutral-600 dark:text-neutral-400"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          id="menu-icon"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-neutral-200/10 md:hidden">
    <div class="flex flex-col gap-4 px-6 py-4">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="mobile-link text-sm font-medium text-neutral-600 transition-colors hover:text-accent dark:text-neutral-400 dark:hover:text-accent-light"
          >
            {link.label}
          </a>
        ))
      }
      <button
        id="dark-toggle-mobile"
        aria-label="Toggle dark mode"
        class="rounded-lg p-2 text-left transition-colors hover:bg-neutral-100 dark:hover:bg-neutral-800 w-fit"
      >
        <svg class="h-5 w-5 text-yellow-400 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <svg class="h-5 w-5 text-neutral-700 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
    </div>
  </div>
</nav>

<script is:inline>
  (function setupNav() {
    // Dark mode toggle
    function toggleDark() {
      var isDark = document.documentElement.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    }
    var dt = document.getElementById("dark-toggle-desktop");
    var dm = document.getElementById("dark-toggle-mobile");
    if (dt) dt.onclick = toggleDark;
    if (dm) dm.onclick = toggleDark;

    // Mobile menu
    var menuToggle = document.getElementById("menu-toggle");
    var menu = document.getElementById("mobile-menu");
    if (menuToggle && menu) {
      menuToggle.onclick = function () { menu.classList.toggle("hidden"); };
      var mobileLinks = menu.querySelectorAll(".mobile-link");
      mobileLinks.forEach(function (link) {
        link.addEventListener("click", function () { menu.classList.add("hidden"); });
      });
    }
  })();
</script>
