---
const versions = [
  { name: 'a-scroll', label: 'Scroll' },
  { name: 'b-card', label: 'Card' },
  { name: 'c-terminal', label: 'Terminal' },
];
const current = 'c-terminal';
---

<div id="version-switcher" class="fixed bottom-4 left-4 z-50 flex items-center gap-1 rounded-full border border-neutral-200 bg-white/80 px-2 py-1 text-xs font-medium shadow-lg backdrop-blur-sm dark:border-neutral-700 dark:bg-neutral-900/80">
  <span class="mr-1 text-neutral-400 dark:text-neutral-500">v</span>
  {versions.map((v) => (
    <a
      href={v.name === current ? '#' : `/?v=${v.name}`}
      class:list={[
        'rounded-full px-2 py-0.5 transition-colors',
        v.name === current
          ? 'bg-accent text-white cursor-default'
          : 'text-neutral-500 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-100',
      ]}
      aria-current={v.name === current ? 'page' : undefined}
    >
      {v.label}
    </a>
  ))}
</div>
