---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Page Not Found">
  <div class="flex min-h-screen items-center justify-center px-6">
    <div class="text-center">
      <p class="mb-2 font-mono text-sm text-accent">404</p>
      <h1 class="mb-4 text-3xl font-bold text-neutral-900 dark:text-neutral-100">
        Page not found
      </h1>
      <p class="mb-8 text-neutral-600 dark:text-neutral-400">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="inline-block rounded-lg bg-accent px-6 py-3 text-sm font-medium text-white transition-all hover:bg-accent-light"
      >
        Go Home
      </a>
    </div>
  </div>
</BaseLayout>
